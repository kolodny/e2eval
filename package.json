{
  "name": "e2eval",
  "version": "0.0.5",
  "description": "Middleware-powered eval framework for real-tool agents. Scrub source evidence from MCP tool results before the agent sees it.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/core/types.d.ts",
      "import": "./dist/core/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-hooks.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^14.0.3",
    "mcp-middleware": "^0.0.1",
    "zod": "^4.3.6",
    "zx": "^8.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "eval",
    "agent",
    "mcp",
    "llm",
    "claude",
    "codex",
    "opencode"
  ],
  "author": "Moshe Kolodny",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolodny/e2eval.git"
  },
  "bugs": {
    "url": "https://github.com/kolodny/e2eval/issues"
  },
  "homepage": "https://github.com/kolodny/e2eval#readme"
}
