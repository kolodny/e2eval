{
  "name": "e2eval",
  "version": "0.2.4",
  "description": "Middleware-powered eval framework for Claude Code. Intercepts the Anthropic API to observe and scrub tool calls.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/core/types.d.ts",
      "import": "./dist/core/types.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "E2EVAL_NO_CLEANUP=1 node --import tsx --test 'tests/**/*.test.ts'",
    "posttest": "rm -rf .eval_runs",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "zx": "^8.3.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "eval",
    "agent",
    "llm",
    "claude",
    "anthropic",
    "proxy"
  ],
  "author": "Moshe Kolodny",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolodny/e2eval.git"
  },
  "bugs": {
    "url": "https://github.com/kolodny/e2eval/issues"
  },
  "homepage": "https://github.com/kolodny/e2eval#readme"
}
